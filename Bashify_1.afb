        {
            "id": "action",
            "instance": "39d42223-b644-4d44-b405-61b4954bd57b",
            "properties": [
                [
                    "name",
                    "Valid Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078"
                        ]
                    ]
                ],
                [
                    "description",
                    "Bashify acquires valid credentials — primarily local account credentials — through stealer malware logs, credential combo lists, and underground markets. The actor's reliance on legitimate accounts as the entry mechanism means initial access generates no brute-force or anomalous login alerts, allowing operations to proceed undetected from first contact."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
