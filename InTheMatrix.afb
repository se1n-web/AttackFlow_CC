        {
            "id": "malware",
            "instance": "6b759aaf-decd-411e-8eb7-a9535263407f",
            "properties": [
                [
                    "name",
                    "RDP Lateral Movement (T1021.001)"
                ],
                [
                    "description",
                    "RDP-based lateral movement is In The Matrix's signature post-access technique at 100 reports — matching the dominance of External Remote Services in the actor's profile. Once inside, the actor pivots across Windows hosts using RDP authenticated with harvested local or domain credentials, enabling interactive access to additional systems. RDP lateral movement is frequently combined with pass-the-hash (T1550.002) and RDP session hijacking (T1563.002) to traverse environments without re-entering credentials."
                ],
                [
                    "malware_types",
                    [
                        [
                            "e53a0602-3b5a-46c1-8e0c-7ac9d585c772",
