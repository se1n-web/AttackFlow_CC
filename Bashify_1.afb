                [
                    "name",
                    "Email Collection (T1114)"
                ],
                [
                    "description",
                    "Bashify collects emails and mailbox contents from compromised mail servers or cloud email platforms, targeting correspondence containing credentials, business intelligence, and sensitive internal communications. Email collection supplements data repository harvesting (T1213), providing the actor with high-value intelligence material for extortion, resale, or further credential harvesting from email threads."
                ],
