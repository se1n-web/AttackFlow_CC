        {
            "id": "action",
            "instance": "41ee0ea8-4036-4064-b8c4-e4b8c6d6472f",
            "properties": [
                [
                    "name",
                    "Domain Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078.002"
                        ]
                    ]
                ],
                [
                    "description",
                    "Domain Accounts is Yayo's second-highest frequency technique at 25 reports — the actor specifically targets and abuses Active Directory domain credentials obtained via stealer logs or credential markets to authenticate to internet-facing services. Domain account access enables broad lateral movement across the AD environment and is the actor's preferred credential class, providing organisation-wide reach from a single set of harvested credentials."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
