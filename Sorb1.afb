        {
            "id": "action",
            "instance": "b1596103-0975-4d4f-b872-7cdccee4c68c",
            "properties": [
                [
                    "name",
                    "Spearphishing Link"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1566.002"
                        ]
                    ]
                ],
                [
                    "description",
                    "Sorb sends emails containing links to spoofed login portals or malware-staging pages. Victims who follow the link either disclose credentials on a fake authentication page or trigger a drive-by download, both of which feed directly into the group's account-based access strategy."
                ],
                [
