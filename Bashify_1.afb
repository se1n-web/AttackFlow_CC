        {
            "id": "malware",
            "instance": "e8291dfc-afea-4cb3-ad48-ac242f1893cd",
            "properties": [
                [
                    "name",
                    "Cloud Services Lateral Movement (T1021.007)"
                ],
                [
                    "description",
                    "Bashify abuses access to cloud management consoles, SaaS platforms, and cloud-hosted applications — authenticated via stolen credentials or session tokens — to move laterally into cloud-hosted data stores and email platforms. Cloud-service lateral movement is observed in four reports, indicating the actor deliberately targets cloud environments as a secondary pivot path alongside SSH-based movement."
                ],
                [
                    "malware_types",
                    [
                        [
                            "cc60679a-1f19-4e15-86fa-c17c1afe9f11",
