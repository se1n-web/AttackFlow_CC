        {
            "id": "action",
            "instance": "d6da95cf-efab-4113-9227-7d23326e1dbd",
            "properties": [
                [
                    "name",
                    "Valid Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078"
                        ]
                    ]
                ],
                [
                    "description",
                    "Yayo acquires valid credentials — targeting both domain and local accounts — through stealer malware logs, credential markets, and prior breach datasets. The actor's credential acquisition spans multiple account tiers, with a strong emphasis on domain-level credentials that enable broad lateral movement across Active Directory environments."
                ],
                [
                    "confidence",
                    null
                ],
