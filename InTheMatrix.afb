                        ],
                        [
                            "technique",
                            "T1133"
                        ]
                    ]
                ],
                [
                    "description",
                    "External Remote Services is In The Matrix's highest-frequency and most dominant technique at 113 reports — far surpassing all other techniques in the actor's profile. The actor gains entry to victim environments through internet-facing RDP gateways, VPN appliances, and remote management services using stolen local and domain credentials. This node anchors all post-access operations: RDP-based lateral movement is the actor's primary pivot technique (100 reports), with email collection and dual C2 channels completing the post-access capability set."
                ],
                [
                    "confidence",
                    null
                ],
