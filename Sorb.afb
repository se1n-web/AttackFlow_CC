        {
            "id": "action",
            "instance": "d5db0b8f-be5e-4c53-91e3-304dee66d286",
            "properties": [
                [
                    "name",
                    "Valid Accounts: Cloud Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078.003"
                        ]
                    ]
                ],
                [
                    "description",
                    "A subset of the compromised credentials grants access to cloud-hosted services (e.g. webmail, SaaS, or cloud-management consoles). Sorb uses these cloud accounts to blend in with legitimate user activity and to maintain access that is harder for on-premises defenses to observe."
                ],
                [
                    "confidence",
                    null
                ],
