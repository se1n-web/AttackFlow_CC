                        ],
                        [
                            "technique",
                            "T1078"
                        ]
                    ]
                ],
                [
                    "description",
                    "Sorb authenticates to victim environments using legitimate credentials obtained through phishing, credential stuffing, or purchase from underground markets. Group-IB reporting shows this technique recurring across initial access, persistence, privilege escalation, and defense evasion, indicating credentials are reused throughout the intrusion lifecycle rather than discarded after first entry."
                ],
