        {
            "id": "action",
            "instance": "b3aa3855-3d85-40ad-b53c-ecca99eaf76b",
            "properties": [
                [
                    "name",
                    "Phishing"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1566"
                        ]
                    ]
                ],
                [
                    "description",
                    "Sorb operators send phishing emails to employees at targeted organizations as a primary initial-access vector, using both malicious attachments and credential-harvesting links to obtain a foothold or capture authentication material that is later reused as valid accounts."
                ],
                [
                    "confidence",
                    null
