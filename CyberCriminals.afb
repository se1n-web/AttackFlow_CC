            "properties": [
                [
                    "name",
                    "Email Collection (T1114)"
                ],
                [
                    "description",
                    "In The Matrix collects emails and mailbox contents from compromised mail servers and cloud email platforms, targeting correspondence containing credentials, business intelligence, sensitive internal communications, and financial data. Email collection complements data repository harvesting (T1213 — 15 reports) to build a comprehensive intelligence picture of the victim organisation for extortion or resale purposes."
                ],
