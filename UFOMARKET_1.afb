            "properties": [
                [
                    "name",
                    "SSH Lateral Movement (T1021.004)"
                ],
                [
                    "description",
                    "UFOMARKET operators pivot across Linux and Unix hosts — as well as network devices and cloud workloads — using SSH with harvested credentials or keys recovered from compromised systems. SSH lateral movement enables the actor to enumerate and access additional internal systems, expanding the scope and value of the access package offered on the marketplace."
                ],
                [
                    "malware_types",
