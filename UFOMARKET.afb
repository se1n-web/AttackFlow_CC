        {
            "id": "action",
            "instance": "f1c843cd-16e5-43c8-bdf2-fb1c24286971",
            "properties": [
                [
                    "name",
                    "Valid Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078"
                        ]
                    ]
                ],
                [
                    "description",
                    "UFOMARKET operators obtain valid credentials from stealer malware logs, credential markets, and prior breach datasets to authenticate to victim environments. Legitimate account use produces no anomalous authentication patterns, enabling the actor to access target systems silently before conducting lateral movement and packaging the compromised access for resale on the UFOMARKET shop."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
