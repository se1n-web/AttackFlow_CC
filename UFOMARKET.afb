        {
            "id": "malware",
            "instance": "adfe1f39-27dc-4bc6-a40f-1248e8adcf7e",
            "properties": [
                [
                    "name",
                    "SMB / Windows Admin Shares (T1021.002)"
                ],
                [
                    "description",
                    "UFOMARKET operators use SMB and Windows administrative shares (C$, ADMIN$) to move laterally across Windows hosts in victim environments, leveraging harvested credentials or pass-the-hash techniques. SMB-based lateral movement allows the actor to access additional systems and validate the breadth of compromised access before packaging it for sale."
                ],
