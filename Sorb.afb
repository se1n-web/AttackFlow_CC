            "properties": [
                [
                    "name",
                    "Spearphishing Attachment"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1566.001"
                        ]
                    ]
                ],
                [
                    "description",
                    "Sorb delivers malicious documents or archives as email attachments. When opened by the recipient, embedded macros or scripts execute a loader, giving the operator initial code execution on the victim host without requiring any exploit."
                ],
