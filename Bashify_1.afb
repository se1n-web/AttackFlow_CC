        {
            "id": "action",
            "instance": "8418ea15-211d-4fdc-8fd5-9187033d5708",
            "properties": [
                [
                    "name",
                    "Local Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078.003"
                        ]
                    ]
                ],
                [
                    "description",
                    "Local Accounts is Bashify's second-highest frequency technique — the actor specifically targets default, reused, or weak local administrator credentials on internet-facing systems to gain access. These credentials are harvested from stealer logs or credential datasets and used to authenticate to RDP, SSH, and management services without requiring domain-level compromise, minimising the attacker's footprint in centralised authentication logs."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
