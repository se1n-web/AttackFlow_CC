        {
            "id": "malware",
            "instance": "16273e35-55bb-4043-a8fe-2710c96e651c",
            "properties": [
                [
                    "name",
                    "Telegram C2 (T1071.002)"
                ],
                [
                    "description",
                    "In The Matrix uses Telegram bots as a command-and-control channel, routing operational commands and exfiltrated data through the platform's application-layer API over standard HTTPS. Telegram C2 is difficult to distinguish from legitimate user traffic on network monitoring systems and provides the actor with a resilient, low-infrastructure channel that is challenging to block without impacting business communications."
                ],
                [
                    "malware_types",
