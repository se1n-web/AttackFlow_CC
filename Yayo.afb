        {
            "id": "action",
            "instance": "09a07373-156b-4d27-9955-8b89a9fa381f",
            "properties": [
                [
                    "name",
                    "Local Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078.003"
                        ]
                    ]
                ],
                [
                    "description",
                    "Yayo abuses local administrator credentials — sourced from stealer logs and credential combo lists — as a secondary access path, authenticating to internet-facing RDP and management services on hosts lacking centralised credential management. Local account access supplements domain credential use and provides a fallback access method when domain accounts are locked or rotated."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
