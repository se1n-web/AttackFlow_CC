        {
            "id": "malware",
            "instance": "3f1ccb4e-6aa5-4d40-8c56-ded23ae80d23",
            "properties": [
                [
                    "name",
                    "Telegram C2 (T1071.002)"
                ],
                [
                    "description",
                    "UFOMARKET uses Telegram bots and channels as a command-and-control and communications layer, routing operational commands and exfiltrated access details through the platform's application-layer API. Telegram's legitimate HTTPS traffic makes C2 communication difficult to distinguish from normal user activity, and the platform serves dual-purpose as both an operational channel and a storefront for advertising compromised access listings."
                ],
                [
                    "malware_types",
                    [
                        [
                            "37326e9f-67d2-4f08-97ae-66fc95cc6cd2",
