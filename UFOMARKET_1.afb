            "properties": [
                [
                    "name",
                    "VNC Remote Access (T1021.005)"
                ],
                [
                    "description",
                    "UFOMARKET operators use VNC to gain graphical remote access to compromised desktops and servers, enabling interactive exploration and validation of victim environments. VNC access is particularly valued in the access broker market as it provides buyers with point-and-click control of target systems, commanding higher resale prices than command-line-only access."
                ],
