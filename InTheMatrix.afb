        {
            "id": "action",
            "instance": "009caed4-baaf-4791-b953-66674b4d045b",
            "properties": [
                [
                    "name",
                    "Local Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078.003"
                        ]
                    ]
                ],
                [
                    "description",
                    "Local Accounts is In The Matrix's second-highest frequency technique at 97 reports — the actor abuses default, reused, or weak local administrator credentials on internet-facing systems as a primary access method. Sourced from stealer logs and credential combo lists, local account access allows authentication to RDP, SSH, and management services without requiring domain-level compromise, minimising the attacker's footprint in centralised AD authentication logs."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
