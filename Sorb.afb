                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1133"
                        ]
                    ]
                ],
                [
                    "description",
                    "Sorb's preferred access path is authenticating to externally exposed remote services such as VPN gateways, RDP, and webmail using valid (including cloud) accounts or footholds gained through exploitation. Reporting attributes this technique to both initial access and persistence, suggesting the same remote-access channel is revisited throughout an intrusion to maintain a stable presence."
                ],
                [
                    "confidence",
                    null
                ],
